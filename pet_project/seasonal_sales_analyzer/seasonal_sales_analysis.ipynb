 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🛒 Анализ сезонных продаж продуктов питания\n",
    "\n",
    "**Автор:** g1dcs  \n",
    "**Дата:** 2026-03-30  \n",
    "\n",
    "Проект для анализа продаж продуктов питания в зависимости от времени года.\n",
    "\n",
    "## 🎯 Цели проекта:\n",
    "1. Определить сезонность продаж по категориям\n",
    "2. Выявить топ-продукты для каждого сезона\n",
    "3. Дать рекомендации по ассортименту\n",
    "4. Проанализировать тренды продаж"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Импорт библиотек"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Настройка визуализаций\n",
    "sns.set_style("whitegrid")\n",
    "plt.rcParams['figure.figsize'] = (14, 6)\n",
    "\n",
    "# Импорт наших модулей\n",
    "from data_generator import generate_sales_data, get_season\n",
    "from seasonal_analyzer import SeasonalSalesAnalyzer\n",
    "\n",
    "print("✅ Библиотеки загружены")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Загрузка и генерация данных"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Генерируем данные о продажах за 2 года\n",
    "# В реальном проекте здесь можно загрузить данные из CSV/БД/API\n",
    "\n",
    "df = generate_sales_data(\n",
    "    start_date='2023-01-01',\n",
    "    end_date='2024-12-31',\n",
    "    n_stores=5,\n",
    "    random_seed=42\n",
    ")\n",
    "\n",
    "print(f"📊 Сгенерировано {len(df):,} записей")\n",
    "print(f"📅 Период: {df['date'].min().date()} - {df['date'].max().date()}")\n",
    "print(f"\n💰 Общая выручка: {df['revenue'].sum():,.0f} руб.")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Просмотр первых строк\n",
    "df.head(10)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Первичный анализ данных (EDA)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Базовая информация\n",
    "print("📋 ИНФОРМАЦИЯ О ДАННЫХ:\n")\n",
    "print(f"Количество записей: {len(df):,}")\n",
    "print(f"Магазинов: {df['store'].nunique()}")\n",
    "print(f"Регионов: {df['region'].nunique()}")\n",
    "print(f"Категорий: {df['category'].nunique()}")\n",
    "print(f"Продуктов: {df['product'].nunique()}")\n",
    "print(f"\nКатегории: {', '.join(df['category'].unique())}")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Статистика по числовым колонкам\n",
    "df[['quantity', 'price', 'revenue']].describe()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Распределение по категориям\n",
    "category_stats = df.groupby('category').agg({\n",
    "    'revenue': ['sum', 'mean'],\n",
    "    'quantity': 'sum',\n",
    "    'product': 'nunique'\n",
    "}).round(2)\n",
    "\n",
    "category_stats.columns = ['_'.join(col).strip() for col in category_stats.columns]\n",
    "category_stats = category_stats.sort_values('revenue_sum', ascending=False)\n",
    "\n",
    "print("📊 Статистика по категориям:\n")\n",
    "category_stats"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Создание анализатора и базовый анализ"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Создаем экземпляр анализатора\n",
    "analyzer = SeasonalSalesAnalyzer(df)\n",
    "\n",
    "# Получаем базовую информацию\n",
    "info = analyzer.get_basic_info()\n",
    "\n",
    "print("📊 БАЗОВАЯ ИНФОРМАЦИЯ:\n")\n",
    "for key, value in info.items():\n",
    "    print(f"  {key}: {value}")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Анализ продаж по сезонам"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Анализ по сезонам\n",
    "season_analysis = analyzer.analyze_by_season()\n",
    "\n",
    "print("📈 АНАЛИЗ ПО СЕЗОНАМ:\n")\n",
    "season_analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Визуализация выручки по сезонам\n",
    "analyzer.plot_seasonal_revenue(save_path='reports/seasonal_revenue.png')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 💡 Выводы по сезонам:\n",
    "- **Лето** - пик продаж (фрукты, овощи, напитки)\n",
    "- **Зима** - рост продаж молочки и выпечки\n",
    "- **Весна/Осень** - стабильные продажи"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Топ продукты по сезонам"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Получаем топ продукты для каждого сезона\n",
    "top_by_season = analyzer.get_top_products_by_season(top_n=10)\n",
    "\n",
    "for season, data in top_by_season.items():\n",
    "    print(f"\n🌿 {season.upper()} - ТОП-5 продуктов:")\n",
    "    print("-" * 50)\n",
    "    for i, row in data.head(5).iterrows():\n",
    "        print(f"{row['rank']}. {row['product']} ({row['category']}) - {row['revenue']:,.0f} руб.")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Тепловая карта сезонности по категориям\n",
    "analyzer.plot_category_seasonality(save_path='reports/category_seasonality.png')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Самые прибыльные продукты (весь период)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Топ-20 самых прибыльных продуктов\n",
    "top_profitable = analyzer.get_most_profitable_products(top_n=20)\n",
    "\n",
    "print("🏆 ТОП-20 САМЫХ ПРИБЫЛЬНЫХ ПРОДУКТОВ:\n")\n",
    "top_profitable[['rank', 'product', 'category', 'total_revenue', 'total_quantity']]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Визуализация топ продуктов\n",
    "analyzer.plot_top_products(season=None, top_n=15, save_path='reports/top_products.png')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Помесячная динамика"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# График помесячной динамики\n",
    "analyzer.plot_monthly_trend(save_path='reports/monthly_trend.png')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Рекомендации по сезонам"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Получаем рекомендации\n",
    "recommendations = analyzer.get_seasonal_recommendations()\n",
    "\n",
    "season_emojis = {'весна': '🌸', 'лето': '☀️', 'осень': '🍂', 'зима': '❄️'}\n",
    "\n",
    "print("💡 РЕКОМЕНДАЦИИ ПО АССОРТИМЕНТУ:\n")\n",
    "for season, products in recommendations.items():\n",
    "    emoji = season_emojis.get(season, '')\n",
    "    print(f"{emoji} {season.upper()} - увеличить запасы:")\n",
    "    for i, product in enumerate(products[:5], 1):\n",
    "        print(f"   {i}. {product}")\n",
    "    print()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 10. Полный отчет"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Генерируем полный отчет\n",
    "report = analyzer.generate_full_report()\n",
    "print(report)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Сохраняем отчет в файл\n",
    "with open('reports/full_report.txt', 'w', encoding='utf-8') as f:\n",
    "    f.write(report)\n",
    "\n",
    "print("✅ Отчет сохранен в reports/full_report.txt")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 11. Детальный анализ по категориям"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Анализ сезонности по категориям\n",
    "category_season = analyzer.analyze_category_seasonality()\n",
    "\n",
    "# Показываем для каждой категории\n",
    "for category in df['category'].unique():\n",
    "    cat_data = category_season[category_season['category'] == category]\n",
    "    cat_data = cat_data.sort_values('revenue_pct_in_category', ascending=False)\n",
    "    \n",
    "    print(f"\n📂 {category.upper()}:")\n",
    "    print("-" * 40)\n",
    "    for _, row in cat_data.iterrows():\n",
    "        print(f"  {row['season']}: {row['revenue_pct_in_category']}% выручки")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 12. Сравнение сезонов"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Визуализация топ продуктов по каждому сезону\n",
    "fig, axes = plt.subplots(2, 2, figsize=(18, 14))\n",
    "axes = axes.flatten()\n",
    "\n",
    "seasons = ['весна', 'лето', 'осень', 'зима']\n",
    "colors = ['#90EE90', '#FFD700', '#FF8C00', '#87CEEB']\n",
    "\n",
    "for idx, (season, color) in enumerate(zip(seasons, colors)):\n",
    "    ax = axes[idx]\n",
    "    \n",
    "    # Получаем топ-10 для сезона\n",
    "    season_df = df[df['season'] == season]\n",
    "    top_products = season_df.groupby('product')['revenue'].sum().sort_values(ascending=False).head(10)\n",
    "    \n",
    "    # Строим график\n",
    "    bars = ax.barh(range(len(top_products)), top_products.values, color=color, edgecolor='black')\n",
    "    ax.set_yticks(range(len(top_products)))\n",
    "    ax.set_yticklabels(top_products.index, fontsize=9)\n",
    "    ax.invert_yaxis()\n",
    "    ax.set_xlabel('Выручка (руб.)')\n",
    "    ax.set_title(f'Топ-10 продуктов - {season}', fontsize=12, fontweight='bold')\n",
    "    ax.xaxis.set_major_formatter(plt.FuncFormatter(lambda x, p: f'{x/1e6:.1f}M'))\n",
    "\n",
    "plt.suptitle('Сравнение топ продуктов по сезонам', fontsize=16, fontweight='bold', y=1.02)\n",
    "plt.tight_layout()\n",
    "plt.savefig('reports/seasons_comparison.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 13. Итоговые выводы"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Сводная таблица ключевых метрик\n",
    "summary = {\n",
    "    'Метрика': [\n",
    "        'Общая выручка',\n",
    "        'Всего продаж (шт.)',\n",
    "        'Средний чек',\n",
    "        'Топ сезон по выручке',\n",
    "        'Самый продаваемый продукт',\n",
    "        'Количество магазинов'\n",
    "    ],\n",
