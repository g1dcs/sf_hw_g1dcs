    "        f"{df['revenue'].sum():,.0f} руб.",\n",
    "        f"{df['quantity'].sum():,.0f} шт.",\n",
    "        f"{df['revenue'].mean():.0f} руб.",\n",
    "        season_analysis.loc[season_analysis['revenue_sum'].idxmax(), 'season'],\n",
    "        top_profitable.iloc[0]['product'],\n",
    "        df['store'].nunique()\n",
    "    ]\n",
    "}\n",
    "\n",
    "summary_df = pd.DataFrame(summary)\n",
    "print("📊 КЛЮЧЕВЫЕ МЕТРИКИ:\n")\n",
    "summary_df"
   ]
  },
  {
